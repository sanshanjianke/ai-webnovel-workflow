        <mxCell id="v_WqhEJTto_6-u_6pPi3-31" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;向量数据库&lt;/h1&gt;&lt;p&gt;以序列、人物的片段为主。片段应该包含指向md文本库的标签。&lt;/p&gt;" vertex="1">
          <mxGeometry height="120" width="180" x="250" y="585" as="geometry" />
        </mxCell>
        <mxCell id="v_WqhEJTto_6-u_6pPi3-32" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;md文本库&lt;/h1&gt;&lt;p&gt;以2000-10000字分割成的小章节。例如片段1，片段2，片段3。其间相互包含很大一部分而不是绝对分割（独立的只占20%左右）。这样可以保证向量数据库的标签不是指向片段中文本的顶部或者底部。&lt;/p&gt;" vertex="1">
          <mxGeometry height="165" width="180" x="450" y="585" as="geometry" />
        </mxCell>
        <mxCell id="v_WqhEJTto_6-u_6pPi3-33" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;知识库检索专家&lt;/h1&gt;&lt;p&gt;读取L2架构层产生的文本。&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;通过RAG方式，确定片段位置和所需内容， 然后阅读对应.md文本库获取细节。&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(0, 0, 0), rgb(255, 255, 255));&quot;&gt;然后agent加工细节，确定需求返回L2 架构层&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="180" x="590" y="220" as="geometry" />
        </mxCell>
      </root>
